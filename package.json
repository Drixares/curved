{
  "name": "curved",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "mprocs",
    "dev:docker": "docker compose up --build",
    "build": "bun run --filter '*' build",
    "checks": "prettier --check . && tsc --noEmit -p packages/web && tsc --noEmit -p packages/api && tsc --noEmit -p packages/ui && tsc --noEmit -p packages/admin && tsc --noEmit -p packages/crons",
    "checks:fix": "prettier --write .",
    "start": "bun run --filter '@curved/api' start",
    "db:generate": "bun run --filter '@curved/api' db:generate",
    "db:migrate": "bun run --filter '@curved/api' db:migrate",
    "db:push": "bun run --filter '@curved/api' db:push",
    "db:pull": "bun run --filter '@curved/api' db:pull",
    "db:studio": "bun run --filter '@curved/api' db:studio",
    "db:check": "bun run --filter '@curved/api' db:check",
    "db:seed": "bun run --filter '@curved/api' db:seed",
    "auth:generate": "bun run --filter '@curved/api' auth:generate",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "dependencies": {}
}
