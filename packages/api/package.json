{
  "name": "@curved/api",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:pull": "bunx drizzle-kit pull",
    "db:studio": "bunx drizzle-kit studio",
    "db:check": "bunx drizzle-kit check",
    "auth:generate": "bunx @better-auth/cli generate --output ./src/db/schema.ts"
  },
  "dependencies": {
    "@react-email/components": "^1.0.9",
    "better-auth": "^1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  }
}
