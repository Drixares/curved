FROM oven/bun:latest

RUN apt-get update && apt-get install -y curl && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then MPROCS_ARCH="linux-aarch64-musl"; \
    else MPROCS_ARCH="linux-x86_64-musl"; fi && \
    curl -fsSL "https://github.com/pvolok/mprocs/releases/download/v0.8.3/mprocs-0.8.3-${MPROCS_ARCH}.tar.gz" | tar xz -C /usr/local/bin && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENTRYPOINT ["/app/scripts/docker-entrypoint.dev.sh"]
